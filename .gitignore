*.rpm
netcheck_*/           # version-stamped deb staging dirs  e.g. netcheck_2.0.0/
debian/.debhelper/
debian/files
debian/*.substvars
debian/*.log
debian/tmp/

# ── PyInstaller ───────────────────────────────────────────────────────────────
*.spec
*.manifest

# ── Test / run-time output ────────────────────────────────────────────────────
result.txt
result.json
result.csv
result.xml
fail-*.txt
result-*.txt
result*.json
result*.csv
result*.xml
combined-*.txt
test-output/
test-results/
.pytest_cache/

# ── Editors / IDEs ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.project
.classpath
.settings/
*.sublime-*

